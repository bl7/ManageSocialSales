# PostgreSQL connection (use these OR DATABASE_URL)
PGHOST=localhost
PGPORT=5432
PGDATABASE=defaultdb
PGUSER=postgres
PGPASSWORD=your-password
PGSSLMODE=disable

# Alternative: single connection string (overrides PG* vars if set)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/defaultdb

JWT_SECRET=change-this-to-a-long-random-string-in-production
SESSION_SECRET=change-this-to-another-long-random-string
NODE_ENV=development

# Required for seed script
ADMIN_EMAIL=admin@shree.com
ADMIN_PASSWORD=change-this-strong-password
